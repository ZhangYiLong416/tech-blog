---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../consts";
import { getPublishedPosts } from "../../lib/posts";

const posts = await getPublishedPosts();
---

<BaseLayout title="文章" description="所有技术文章和工程笔记。">
  <section class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">Archive</p>
        <h1>文章</h1>
        <p>所有公开发布的技术笔记，按发布时间倒序排列。</p>
      </div>
    </div>
    <div class="article-list">
      {
        posts.map((post) => (
          <a class="article-row" href={withBase(`/posts/${post.id}/`)}>
            <time class="meta" datetime={post.data.published.toISOString()}>
              {post.data.published.toLocaleDateString("zh-CN")}
            </time>
            <div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="tag-list">
                {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
