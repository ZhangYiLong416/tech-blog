---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { SITE, withBase } from "../consts";
import { getPublishedPosts } from "../lib/posts";

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 3);
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <section class="container hero">
    <div>
      <p class="eyebrow">个人技术博客</p>
      <h1>把工程实践写成可以复用的经验。</h1>
      <p class="lead">
        这里记录系统设计、后端工程、前端工具链、运维部署和日常问题排查。文章会尽量写清楚背景、取舍和验证过程。
      </p>
      <div class="actions">
        <a class="button" href={withBase("/posts/")}>阅读文章</a>
        <a class="button secondary" href={withBase("/about/")}>了解我</a>
      </div>
    </div>
    <aside class="hero-panel">
      <p>
        博客的目标不是堆满功能，而是形成一个长期可维护的技术档案：问题如何出现，方案如何选择，结果如何验证。
      </p>
    </aside>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <h2>最新文章</h2>
        <p>从真实问题里提炼笔记，让之后的自己和读者都能少走一点弯路。</p>
      </div>
      <a class="button secondary" href={withBase("/posts/")}>全部文章</a>
    </div>
    <div class="post-grid">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="container section">
    <div class="info-grid">
      <div class="info-item">
        <h3>工程实践</h3>
        <p>记录架构、性能、部署、监控和稳定性相关的实际经验。</p>
      </div>
      <div class="info-item">
        <h3>工具链</h3>
        <p>整理提升开发效率的脚手架、自动化、编辑器和命令行工作流。</p>
      </div>
      <div class="info-item">
        <h3>复盘笔记</h3>
        <p>把踩坑过程写完整，保留上下文、约束、判断和验证结果。</p>
      </div>
    </div>
  </section>
</BaseLayout>
