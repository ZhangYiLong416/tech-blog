---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../consts";
import { getAllTags } from "../../lib/posts";

const tags = await getAllTags();
---

<BaseLayout title="标签" description="按标签浏览技术文章。">
  <section class="container">
    <div class="section-head">
      <div>
        <p class="eyebrow">Topics</p>
        <h1>标签</h1>
        <p>用主题把文章串起来，方便回看同一类问题的演进。</p>
      </div>
    </div>
    <div class="tag-list">
      {tags.map(([tag, count]) => <a class="tag" href={withBase(`/tags/${encodeURIComponent(tag)}/`)}>{tag} · {count}</a>)}
    </div>
  </section>
</BaseLayout>
